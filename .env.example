# Copy to .env and fill in from your Supabase project (Settings -> API).
# These PUBLIC_ vars are exposed to the browser by SvelteKit — only the anon key belongs here.
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# The shared reporter secret. It is embedded in the QR-code URL handed to camp members
# (/melden/<token>) and validated by the `melden` Edge Function. Rotate by changing it here
# and on the function, then repoint the QR redirect. NOT prefixed PUBLIC_ on the server side —
# see supabase/functions/melden for the server-side env (REPORTER_TOKEN).
PUBLIC_REPORTER_TOKEN_HINT="(the token lives in the URL; nothing secret is stored in the client build)"
