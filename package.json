{
  "name": "zelt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spatz tent fleet damage-reporting PWA (Zelt-Verwaltung)",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
